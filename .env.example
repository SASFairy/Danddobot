# Discord API Configuration
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# LLM Integration Settings
# Options: OLLAMA, OPENAI_COMPATIBLE, LLAMA_CPP, VLLM, LM_STUDIO, CEREBRAS
LLM_PROVIDER=OLLAMA
LLM_API_URL=http://local-llm:11434
LLM_MODEL=llama3
# Timeout in seconds for LLM response generation.
# Set to 0 or less (e.g. 0, -1) for unlimited/infinite timeout (no timeout).
# Default is 300.0.
LLM_TIMEOUT=300.0

# LLM Engine-specific API URLs for dynamic switching in Admin Dashboard.
# Only the engines that have their corresponding API URL uncommented/defined below
# will be listed in the Admin Dashboard's LLM Provider dropdown menu.
OLLAMA_API_URL=http://local-llm:11434
# OPENAI_COMPATIBLE_API_URL=http://localhost:8000
# LLAMA_CPP_API_URL=http://localhost:8080
# VLLM_API_URL=http://vllm-container:8000
# LM_STUDIO_API_URL=http://localhost:1234
# CEREBRAS_API_URL=https://api.cerebras.ai
# CEREBRAS_API_KEY=your_cerebras_api_key_here

# Persona prompt file configuration
# Points to the text file containing the bot's system instructions
PERSONA_FILE_PATH=config/persona.txt

# Registered chat channels configuration
# Points to the text file listing registered channel IDs (one per line with optional # alias)
CHANNELS_FILE_PATH=config/channels.txt

# Private Admin Channel configuration (optional)
# If provided, the bot will post an interactive dashboard to this channel.
# Leave blank or omit to disable the admin dashboard.
ADMIN_CHANNEL_ID=

# Log Channel configuration (optional)
# If provided, bot system errors are sent here instead of the active chat channel.
# Leave blank or omit to disable the dedicated log channel.
LOG_CHANNEL_ID=


# RAG (Retrieval-Augmented Generation) Settings
# Enable/Disable RAG features. Options: TRUE, FALSE (Default: FALSE)
RAG_ENABLED=FALSE

# Directory to scan for text documents (.txt) to build the bot's knowledge base.
# Default is config/knowledge.
RAG_KNOWLEDGE_DIR=config/knowledge

# Number of most relevant document chunks/paragraphs to retrieve as context.
# Default is 3.
RAG_TOP_K=3

# Maximum total character limit for the retrieved context combined.
# Helps avoid LLM context window overflow and keeps responses concise.
# Default is 1500.
RAG_MAX_CHARS=1500

# Maximum character size for each sliced chunk.
# Paragraphs exceeding this limit will be split cleanly at sentence boundaries.
# Must be less than or equal to RAG_MAX_CHARS.
# Default is 500.
RAG_CHUNK_SIZE=500
