# Discord API Configuration
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_CHANNEL_ID=YOUR_TARGET_CHANNEL_ID_HERE

# LLM Integration Settings
# Options: OLLAMA, OPENAI_COMPATIBLE, LLAMA_CPP, VLLM, LM_STUDIO
LLM_PROVIDER=OLLAMA
LLM_API_URL=http://local-llm:11434
LLM_MODEL=llama3

# Persona prompt file configuration
# Points to the text file containing the bot's system instructions
PERSONA_FILE_PATH=config/persona.txt

# Private Admin Channel configuration (optional)
# If provided, the bot will post an interactive dashboard to this channel.
# Leave blank or omit to disable the admin dashboard.
ADMIN_CHANNEL_ID=

